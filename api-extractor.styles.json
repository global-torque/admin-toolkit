{
  "$schema": "https://developer.microsoft.com/json-schemas/api-extractor/v7/api-extractor.schema.json",
  "mainEntryPointFilePath": "<projectFolder>/dist/styles.d.ts",
  "apiReport": {
    "enabled": true,
    "reportFileName": "admin-toolkit-styles.api.md",
    "reportFolder": "<projectFolder>/etc",
    "reportTempFolder": "<projectFolder>/temp/api-report"
  },
  "docModel": {
    "enabled": true,
    "apiJsonFilePath": "<projectFolder>/temp/styles/admin-toolkit-styles.api.json"
  },
  "dtsRollup": { "enabled": false },
  "tsdocMetadata": { "enabled": false },
  "messages": {
    "extractorMessageReporting": {
      "ae-missing-release-tag": { "logLevel": "error" },
      "ae-forgotten-export": { "logLevel": "error" }
    }
  }
}
